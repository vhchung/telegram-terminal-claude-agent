# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Security: Only allow this Telegram user
# Use EITHER username (easier) OR numeric ID
# Username: Don't include the @ symbol
ADMIN_USERNAME=your_telegram_username
# OR numeric ID (optional, can be left empty if using username)
ADMIN_ID=

# Optional: Claude CLI path (default: 'claude')
CLAUDE_CLI_PATH=claude

# Working Directory Restriction
# All commands will be executed in this directory
# Use absolute path or relative to the bot's working directory
# If not set, defaults to the current directory where the bot is running
# Example: /home/user/projects or ./my-project
WORKING_DIR=
