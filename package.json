{
  "name": "telegram-terminal-claude-agent",
  "version": "1.0.0",
  "description": "Telegram Chatbot with Claude Code integration and terminal bridge",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "type-check": "tsc --noEmit",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop telegram-claude-bot",
    "pm2:restart": "pm2 restart telegram-claude-bot",
    "pm2:logs": "pm2 logs telegram-claude-bot",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.34.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
